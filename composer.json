{
  "name": "maatify/shared-common",
  "description": "Fundamental contracts and shared abstractions for Maatify modules, including clock and telemetry interfaces.",
  "type": "library",
  "license": "MIT",

  "require": {
    "php": "^8.2"
  },


  "require-dev": {
    "php-di/php-di": "^7.0",
    "slim/psr7": "^1.8",
    "friendsofphp/php-cs-fixer": "^3.94",
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^11.0"
  },

  "autoload": {
    "psr-4": {
      "Maatify\\SharedCommon\\": "src/"
    }
  },

  "autoload-dev": {
    "psr-4": {
      "Maatify\\SharedCommon\\Tests\\": "tests/"
    }
  },

  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.2.0"
    }
  },

  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse src tests --level=max",
    "format": "php-cs-fixer fix"
  },

  "minimum-stability": "stable",
  "prefer-stable": true,

  "keywords": [
    "shared",
    "common",
    "contracts",
    "clock",
    "telemetry",
    "security",
    "maatify"
  ],

  "authors": [
    {
      "name": "Maatify",
      "email": "support@maatify.com"
    }
  ],

  "support": {
    "issues": "https://github.com/maatify/shared-common/issues",
    "source": "https://github.com/maatify/shared-common"
  }
}